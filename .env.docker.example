# Docker 环境配置示例

# 复制此文件为 .env.docker 并修改配置

# 数据库配置 (Docker 网络内部 - 不需要修改)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cohort_db

# AI 服务配置
# 提供商选择：anthropic | openai | deepseek | moonshot | aliyun | siliconflow | custom
LLM_PROVIDER=anthropic

# ============= 国际 API =============

# Anthropic (Claude) - 官方 API
# 获取：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o) - 官方 API
# 获取：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============= 国内 API =============

# DeepSeek (深度求索) - 兼容 OpenAI 格式
# 获取：https://platform.deepseek.com/api_keys
# 模型支持：deepseek-chat, deepseek-coder
# 注意：基础模型可能不支持视觉，建议使用 deepseek-vl
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Moonshot (Kimi/月之暗面) - 兼容 OpenAI 格式
# 获取：https://platform.moonshot.cn/console/api-keys
# 模型支持：moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn
MOONSHOT_MODEL=moonshot-v1-8k

# 阿里云 (通义千问) - 兼容 OpenAI 格式
# 获取：https://dashscope.console.aliyun.com/apiKey
# 模型支持：qwen-vl-max (支持视觉), qwen-plus, qwen-max
ALIYUN_API_KEY=
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL=qwen-vl-max

# SiliconFlow (硅基流动) - 兼容 OpenAI 格式
# 获取：https://cloud.siliconflow.cn/account/ak
# 模型支持：Qwen/Qwen2.5-VL-72B-Instruct 等开源视觉模型
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# ============= 自定义 API =============
# 可用于其他兼容 OpenAI 格式的服务

CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# JWT 配置 (生产环境请修改)
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件存储配置
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/app/data/storage

# CORS 配置
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8000"]
